{
  "ConnectionStrings": {
    "DefaultConnection": "Server=.;Database=SecureMultiTenantDb;Trusted_Connection=True;TrustServerCertificate=True"
  },
  "Jwt": {
    "Issuer": "SecureMultiTenant.Api",
    "Audience": "SecureMultiTenant.Client",
    "SigningKey": "REPLACE_WITH_A_LONG_RANDOM_64_PLUS_CHAR_SECRET",
    "AccessTokenMinutes": 30,
    "RefreshTokenDays": 7
  },
  "Authentication": {
    "Entra": {
      "TenantId": "YOUR_ENTRA_TENANT_ID",
      "ClientId": "YOUR_ENTRA_APP_REGISTRATION_CLIENT_ID",
      "Instance": "https://login.microsoftonline.com",
      "ValidIssuer": "https://login.microsoftonline.com/YOUR_ENTRA_TENANT_ID/v2.0",
      "MetadataAddress": null,
      "EnableJitProvisioning": true,
      "DefaultJitRole": "ApplicationUser",
      "RequireEmailClaim": true,
      "RequireInvitationForJitProvisioning": true
    }
  },
  "Security": {
    "AllowSwagger": true,
    "LogRequestResponseBodies": false
  }
}
